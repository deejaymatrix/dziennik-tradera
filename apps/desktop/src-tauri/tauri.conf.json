{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dziennik Tradera",
  "version": "0.1.0",
  "identifier": "com.dziennik-tradera.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dziennik Tradera",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3RjFDOEQ0N0NGNzU4RjEKUldUeFdQZDgxTWp4NTBTK3VDajhPVGNBODBiaVdXWGRHSE5FZGdmSERnYUFOZlpaelpmZkt5UnEK",
      "endpoints": [
        "https://github.com/TWOJA-NAZWA-UZYTKOWNIKA/dziennik-tradera/releases/latest/download/latest.json"
      ]
    }
  }
}
