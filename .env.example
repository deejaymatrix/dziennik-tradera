# Plik wzorcowy zmiennych środowiskowych. Skopiuj do .env i uzupełnij lokalnie.
# NIGDY nie commituj pliku .env ani prawdziwych sekretów do repozytorium.

# --- Supabase (backend, PostgreSQL, Auth, Storage) ---
# Publiczny URL projektu Supabase, np. https://xxxx.supabase.co
VITE_SUPABASE_URL=
# Publiczny klucz anon (bezpieczny do umieszczenia w kliencie)
VITE_SUPABASE_ANON_KEY=
# Klucz service-role - WYŁĄCZNIE dla Edge Functions / środowiska serwerowego.
# Nigdy nie może trafić do apps/web ani apps/desktop.
SUPABASE_SERVICE_ROLE_KEY=

# --- Aplikacja ---
# Środowisko: development | staging | production
APP_ENV=development
# Waluta raportowa domyślna dla nowych profili (użytkownik może zmienić)
APP_DEFAULT_REPORTING_CURRENCY=EUR
# Domyślna strefa czasowa dla nowych profili
APP_DEFAULT_TIMEZONE=Europe/Amsterdam

# --- Asystent AI (opcjonalny, wymienny adapter) ---
# Dostawca: none | local | openai-compatible | anthropic | inny skonfigurowany adapter
AI_PROVIDER=none
AI_PROVIDER_BASE_URL=
AI_PROVIDER_API_KEY=

# --- Aktualizacje desktopowe (Tauri updater) ---
# URL manifestu aktualizacji dla kanału stable
TAURI_UPDATER_MANIFEST_URL_STABLE=
# URL manifestu aktualizacji dla kanału beta/internal
TAURI_UPDATER_MANIFEST_URL_BETA=
# Klucz PUBLICZNY podpisu aktualizatora (prywatny klucz wyłącznie w sekretach CI)
TAURI_UPDATER_PUBKEY=

# --- Podpis kodu Windows (Authenticode) ---
# Wyłącznie referencje/ścieżki używane w pipeline CI, nigdy sam certyfikat/hasło.
WINDOWS_CODESIGN_CERT_THUMBPRINT=
WINDOWS_CODESIGN_TIMESTAMP_URL=http://timestamp.digicert.com

# --- Cloudflare (hosting web, R2 dla artefaktów aktualizatora) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_PAGES_PROJECT=

# --- Telemetria/diagnostyka ---
# Domyślnie wyłączona zgodnie ze specyfikacją (decyzja nr 64).
DIAGNOSTICS_TELEMETRY_ENABLED=false
